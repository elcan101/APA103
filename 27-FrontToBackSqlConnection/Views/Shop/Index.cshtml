@model ShopVM

<main class="main-content">
    <div class="breadcrumb-area breadcrumb-height">
        <div class="container h-100">
            <div class="row h-100">
                <div class="col-lg-12">
                    <div class="breadcrumb-item">
                        <h2 class="breadcrumb-heading">Shop</h2>
                        <ul>
                            <li>
                                <a asp-controller="Home" asp-action="Index">Home</a>
                            </li>
                            <li>Shop Default</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="shop-area section-space-y-axis-100">
        <div class="container">
            <div class="row">
                <div class="col-xl-3 col-lg-4 order-2 order-lg-1 pt-5 pt-lg-0">
                    <div class="sidebar-area">
                        <div class="widgets-searchbox">
                            <form id="widgets-searchbox">
                                <input class="input-field" type="text" placeholder="Search" />
                                <button class="widgets-searchbox-btn" type="submit">
                                    <i class="fa fa-search"></i>
                                </button>
                            </form>
                        </div>
                        <div class="widgets-area">
                            <div class="widgets-item pt-0">
                                <h2 class="widgets-title mb-4">Categories</h2>
                                <ul class="widgets-category">
                                    <li>
                                        <a href="#">
                                            <i class="fa fa-chevron-right"></i>
                                            All <span>(@Model.ProductCount)</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a href="#">
                                            <i class="fa fa-chevron-right"></i>
                                            Featured <span>(@Model.Products.Count(p => p.IsFeatured))</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a href="#">
                                            <i class="fa fa-chevron-right"></i>
                                            New <span>(@Model.Products.Count(p => p.IsNew))</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a href="#">
                                            <i class="fa fa-chevron-right"></i>
                                            Best Seller <span>(@Model.Products.Count(p => p.IsBestSeller))</span>
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-xl-9 col-lg-8 order-1 order-lg-2">
                    <div class="product-topbar">
                        <ul>
                            <li class="page-count">
                                <span>@Model.ProductCount</span> Product Found
                            </li>
                        </ul>
                    </div>

                    <div class="product-grid-view row g-y-20">
                        @foreach (Product product in Model.Products)
                        {
                            <div class="col-md-4 col-sm-6">
                                <div class="product-item">
                                    <div class="product-img">
                                        <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.Id">
                                            <img class="primary-img"
                                                 src="~/images/@product.Image"
                                                 alt="@product.Name" />
                                            <img class="secondary-img"
                                                 src="~/images/@(product.HoverImage ?? product.Image)"
                                                 alt="@product.Name" />
                                        </a>
                                        <div class="product-add-action">
                                            <ul>
                                                <li>
                                                    <a href="#" data-tippy="Add to wishlist">
                                                        <i class="pe-7s-like"></i>
                                                    </a>
                                                </li>
                                                <li>
                                                    <a asp-controller="Product"
                                                       asp-action="Detail"
                                                       asp-route-id="@product.Id"
                                                       data-tippy="Quickview">
                                                        <i class="pe-7s-look"></i>
                                                    </a>
                                                </li>
                                                <li>
                                                    <a href="#" data-tippy="Add to cart">
                                                        <i class="pe-7s-cart"></i>
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    </div>
                                    <div class="product-content">
                                        <a class="product-name"
                                           asp-controller="Product"
                                           asp-action="Detail"
                                           asp-route-id="@product.Id">@product.Name</a>
                                        <div class="price-box pb-1">
                                            <span class="new-price">$@product.Price.ToString("0.00")</span>
                                        </div>
                                        <div class="rating-box">
                                            <ul>
                                                @for (int i = 0; i < 5; i++)
                                                {
                                                    <li><i class="fa fa-star"></i></li>
                                                }
                                            </ul>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>
