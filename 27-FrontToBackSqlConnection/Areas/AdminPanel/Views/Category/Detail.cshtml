@model Category

<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">
            <div class="col-md-6 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">Category Detail</h4>
                        <p>Name: @Model.Name</p>
                        <p>Products: @Model.Products.Count</p>
                        <a asp-action="Index" class="btn btn-light">Back</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
