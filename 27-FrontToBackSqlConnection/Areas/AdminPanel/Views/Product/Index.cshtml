@model List<Product>

<div class="main-panel">
    <div class="content-wrapper">
        <div class="row">
            <div class="col-lg-12 grid-margin stretch-card">
                <div class="card">
                    <div class="card-body">
                        <h4 class="card-title">Product Table</h4>
                        <a asp-action="Create" class="btn btn-outline-success mb-4">Create</a>
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>No</th>
                                        <th>Image</th>
                                        <th>Name</th>
                                        <th>Category</th>
                                        <th>SKU</th>
                                        <th>Price</th>
                                        <th>Featured</th>
                                        <th>New</th>
                                        <th>Best Seller</th>
                                        <th>Settings</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int count = 0;
                                    }
                                    @foreach (Product product in Model)
                                    {
                                        count++;
                                        <tr>
                                            <td>
                                                <p>@count</p>
                                            </td>
                                            <td>
                                                <img src="~/images/@product.Image" alt="@product.Name" />
                                            </td>
                                            <td>
                                                <p>@product.Name</p>
                                            </td>
                                            <td>
                                                <p>@product.Category.Name</p>
                                            </td>
                                            <td>
                                                <p>@product.SKU</p>
                                            </td>
                                            <td>
                                                <p>$@product.Price.ToString("0.00")</p>
                                            </td>
                                            <td>
                                                <p>@product.IsFeatured</p>
                                            </td>
                                            <td>
                                                <p>@product.IsNew</p>
                                            </td>
                                            <td>
                                                <p>@product.IsBestSeller</p>
                                            </td>
                                            <td>
                                                <a asp-action="Update" asp-route-id="@product.Id" class="btn btn-outline-warning">Edit</a>
                                                <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-outline-danger">Delete</a>
                                                <a asp-action="Detail" asp-route-id="@product.Id" class="btn btn-outline-primary">Detail</a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
